# =============================================
# AWGP Audio Catalog - .gitignore
# =============================================

# ---- Node Modules ----
node_modules/
**/node_modules/

# ---- Environment Variables (sensitive data - never commit!) ----
.env
**/.env
!**/.env.example

# ---- Build Outputs ----
frontend/dist/
frontend/build/

# ---- Uploaded Media (user files) ----
backend/uploads/*
!backend/uploads/.gitkeep

# ---- Logs ----
backend/server.log
*.log
logs/

# ---- Debug / Test Files ----
backend/server-debug.js
backend/server-debug2.js
backend/server-log.js
backend/test-connection.js
backend/test-db.js
backend/test-load.js

# ---- Backup / Archive Files ----
backups/
*.zip
*.tar.gz

# ---- Misc Folders ----
githubfolder/
AWGP_AUDIO_CATALOG/

# ---- IDE & OS Files ----
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ---- Package Manager Caches ----
.npm
.yarn

# ---- Local README (do not track) ----
README.md
