{
    "name": "audio-catalog-monorepo",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "dev": "concurrently --names \"FRONTEND,BACKEND\" --prefix-colors \"cyan,green\" \"node frontend/node_modules/.bin/vite.js\" \"node_modules/.bin/nodemon backend/server.js\"",
        "build": "npm run build --prefix frontend",
        "start": "npm run dev",
        "backup": "cd scripts && powershell -ExecutionPolicy Bypass -File backup-windows.ps1",
        "backup:linux": "cd scripts && chmod +x backup-linux.sh && ./backup-linux.sh",
        "restore": "cd scripts && powershell -ExecutionPolicy Bypass -File restore-windows.ps1",
        "restore:linux": "cd scripts && chmod +x restore-linux.sh && ./restore-linux.sh"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "dotenv": "^16.4.5",
        "mongoose": "^8.19.2",
        "express": "^4.18.2",
        "multer": "^2.1.0"
    },
    "allowScripts": {
        "esbuild@0.21.5": true,
        "ffmpeg-static@5.3.0": true
    },
    "license": "MIT"
}
